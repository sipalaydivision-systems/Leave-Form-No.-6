# Environment Variables - Copy this to .env and fill in actual values
# DO NOT commit .env to GitHub - it contains sensitive information

# ── PostgreSQL (Neon) - REQUIRED ──────────────────────────
# Get your connection string from https://neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Server Configuration
NODE_ENV=production
PORT=3000

# Production Domain (your actual domain)
# Examples:
#   http://localhost:3000 (development)
#   https://leaveform.railway.app (Railway deployment)
#   https://leaveform.render.com (Render deployment)
#   https://leaveform.deped.gov.ph (custom domain)
PRODUCTION_DOMAIN=https://yourdomain.com

# Email Service - MailerSend Configuration
# Get your API key from https://app.mailersend.com/api
MAILERSEND_API_KEY=your_actual_mailersend_api_key_here

# Email sender address (must be verified in MailerSend dashboard)
MAILERSEND_SENDER_EMAIL=noreply@yourdomain.mlsender.net

# Optional: Cloudflare R2 (PDF file storage)
# If not set, PDFs stay as base64 in the database.
# R2_ACCOUNT_ID=your_account_id
# R2_ACCESS_KEY_ID=your_access_key
# R2_SECRET_ACCESS_KEY=your_secret_key
# R2_BUCKET_NAME=leave-form-pdfs

# Optional: Data Seed Key
# DATA_SEED_KEY=sipalay-sdo-2026-seed
